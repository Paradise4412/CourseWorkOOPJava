@startuml ComponentDiagram
skinparam componentStyle rectangle
skinparam shadowing false

title Диаграмма компонентов\nИнформационная система учёта задержаний

package "Приложение" {
  [DetentionRegistryApplication] as app
  [ConsoleApplication] as ui
  [DetentionRepository] as repo
  [DatabaseConnectionManager] as db
  [DetentionEntity\nDetentionStatus] as domain
}

database "H2\n(database/detention_registry)" as h2

app --> ui
ui --> repo
repo --> db
db --> h2
repo --> domain
ui --> domain

@enduml
